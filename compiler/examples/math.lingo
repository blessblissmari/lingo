# mixed-mode arithmetic, comparison, branching.

fn classify(n: i64) -> str:
    if n < 0:
        return "neg"
    elif n == 0:
        return "zero"
    else:
        return "pos"

fn main():
    let mut total = 0
    for i in 1..6:
        total = total + i * i
    print("sum of squares 1..5:", total)
    print(classify(-3), classify(0), classify(7))
    print(2 ** 10, 7 % 3, 22 / 7)
